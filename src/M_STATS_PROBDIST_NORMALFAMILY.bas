Public Function K_STATS_Normal_IntervalProbability( _
    ByVal LowerBound As Double, _
    ByVal UpperBound As Double, _
    Optional ByVal Mean As Double = 0#, _
    Optional ByVal StdDev As Double = 1#, _
    Optional ByRef Status As String = "") _
    As Variant
'
'==============================================================================
' K_STATS_Normal_IntervalProbability
'------------------------------------------------------------------------------
' PURPOSE
'   Returns P(LowerBound <= X <= UpperBound) for a normal distribution with the
'   given mean and standard deviation.
'
' WHY THIS EXISTS
'   Band probabilities on a general normal are used for tolerance masses,
'   confidence-interval coverage and probability-in-range calculations.
'
' WORKSHEET EQUIVALENT
'   NORM.DIST(UpperBound, Mean, StdDev, TRUE) - NORM.DIST(LowerBound, Mean, StdDev, TRUE).
'
' PROVENANCE
'   Standardization followed by tail-oriented normal interval identities. Not proprietary.
'
' INPUTS
'   LowerBound
'     Lower evaluation bound.
'
'   UpperBound
'     Upper evaluation bound.
'     Must be greater than or equal to LowerBound.
'
'   Mean
'     Distribution mean.
'
'   StdDev
'     Distribution standard deviation.
'     Must be strictly positive.
'
'   Status
'     Optional ByRef diagnostic message.
'
' RETURNS
'   Variant
'     Success => Double interval probability in [0, 1].
'     Failure => CVErr(xlErrNum) or CVErr(xlErrValue).
'
' BEHAVIOR
'   - Validates finite bounds, finite Mean and positive StdDev.
'   - Validates UpperBound >= LowerBound.
'   - Standardizes both bounds and delegates to the stable interval kernel.
'   - Clamps final rounding residuals to [0, 1].
'
' ERROR POLICY
'   - Invalid or reversed bounds return CVErr(xlErrNum).
'   - Unexpected runtime errors return CVErr(xlErrValue).
'   - Detailed diagnostic messages are written to Status (status bar only when
'     PROB_WRITE_STATUS_BAR is True).
'
' DEPENDENCIES
'   - PROB_IsFinite
'   - PROB_NormalIntervalProbability
'   - PROB_SetStatus
'
' UPDATED
'   2026-07-08
'==============================================================================
'
'------------------------------------------------------------------------------
' DECLARE
'------------------------------------------------------------------------------
    Dim ZLower              As Double          'Standardized lower bound
    Dim ZUpper              As Double          'Standardized upper bound
    Dim Probability         As Double          'Interval probability
    Dim FailMsg             As String          'Detailed failure message
'------------------------------------------------------------------------------
' INITIALIZE
'------------------------------------------------------------------------------
    'Route unexpected runtime errors to the error handler
        On Error GoTo Err_Handler
    'Clear diagnostic status
        PROB_SetStatus Status, vbNullString
    'Initialize the failure message buffer
        FailMsg = vbNullString
'------------------------------------------------------------------------------
' VALIDATE INPUTS
'------------------------------------------------------------------------------
    'Validate finite bounds
        If Not PROB_IsWithinSupportedMagnitude(LowerBound) Then
            FailMsg = "LowerBound must be a finite number"
            GoTo Fail_Num
        End If

        If Not PROB_IsWithinSupportedMagnitude(UpperBound) Then
            FailMsg = "UpperBound must be a finite number"
            GoTo Fail_Num
        End If
    'Validate distribution parameters
        If Not PROB_IsWithinSupportedMagnitude(Mean) Then
            FailMsg = "Mean must be a finite number"
            GoTo Fail_Num
        End If

        If Not PROB_IsWithinSupportedMagnitude(StdDev) Or StdDev <= 0# Then
            FailMsg = "StdDev must be a finite strictly positive number"
            GoTo Fail_Num
        End If
    'Validate ordering
        If UpperBound < LowerBound Then
            FailMsg = "UpperBound must be greater than or equal to LowerBound"
            GoTo Fail_Num
        End If
'------------------------------------------------------------------------------
' COMPUTE INTERVAL PROBABILITY
'------------------------------------------------------------------------------
    'Standardize both bounds
        ZLower = (LowerBound - Mean) / StdDev
        ZUpper = (UpperBound - Mean) / StdDev
    'Use the stable standardized interval kernel.
        Probability = PROB_NormalIntervalProbability(ZLower, ZUpper)
    'Return interval probability
        K_STATS_Normal_IntervalProbability = Probability
'------------------------------------------------------------------------------
' RETURN SUCCESS
'------------------------------------------------------------------------------
    'Clear diagnostic status
        PROB_SetStatus Status, vbNullString
    'Exit before failure and error-handler blocks
        Exit Function
'------------------------------------------------------------------------------
' FAIL - NUMERIC
'------------------------------------------------------------------------------
Fail_Num:
    'Write diagnostics
        PROB_SetStatus Status, FailMsg
    'Return worksheet numeric error
        K_STATS_Normal_IntervalProbability = CVErr(xlErrNum)
    'Exit before the error handler
        Exit Function
'------------------------------------------------------------------------------
' ERROR HANDLER
'------------------------------------------------------------------------------
Err_Handler:
    'Write unexpected runtime errors to diagnostics
        PROB_SetStatus Status, "Unexpected error in K_STATS_Normal_IntervalProbability: " & Err.Description
    'Return worksheet value error
        K_STATS_Normal_IntervalProbability = CVErr(xlErrValue)
End Function


