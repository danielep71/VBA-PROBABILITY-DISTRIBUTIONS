'   - PROB_SetStatus
'
' UPDATED
'   2026-07-08
'==============================================================================
'
'------------------------------------------------------------------------------
' DECLARE
'------------------------------------------------------------------------------
    Dim MeanValue           As Double          'Arithmetic mean
    Dim FailMsg             As String          'Detailed failure message
'------------------------------------------------------------------------------
' INITIALIZE
