'------------------------------------------------------------------------------
    'Validate X is finite
        If Not PROB_IsFinite(X) Then
            FailMsg = "X must be a finite number"
            GoTo Fail_Num
        End If
    'Validate lognormal parameters
        If Not PROB_IsFinite(MeanLog) Then
            FailMsg = "MeanLog must be a finite number"
            GoTo Fail_Num
        End If

        If Not PROB_IsFinite(StdDevLog) Or StdDevLog <= 0# Then
            FailMsg = "StdDevLog must be a finite strictly positive number"
            GoTo Fail_Num
        End If
'------------------------------------------------------------------------------
' COMPUTE CUMULATIVE PROBABILITY
'------------------------------------------------------------------------------
    'Return zero for non-positive evaluation points
        If X <= 0# Then
            K_STATS_Lognormal_Cumulative = 0#
            PROB_SetStatus Status, vbNullString
            Exit Function
        End If
    'Compute standardized log variate
        Z = (Log(X) - MeanLog) / StdDevLog
    'Return lognormal cumulative probability
        K_STATS_Lognormal_Cumulative = PROB_NormalCDF(Z)
'------------------------------------------------------------------------------
' RETURN SUCCESS
'------------------------------------------------------------------------------
    'Clear diagnostic status
        PROB_SetStatus Status, vbNullString
    'Exit before failure and error-handler blocks
        Exit Function
'------------------------------------------------------------------------------
' FAIL - NUMERIC
'------------------------------------------------------------------------------
Fail_Num:
    'Write diagnostics
        PROB_SetStatus Status, FailMsg
    'Return worksheet numeric error
        K_STATS_Lognormal_Cumulative = CVErr(xlErrNum)
    'Exit before the error handler
        Exit Function
'------------------------------------------------------------------------------
' ERROR HANDLER
'------------------------------------------------------------------------------
Err_Handler:
    'Write unexpected runtime errors to diagnostics
