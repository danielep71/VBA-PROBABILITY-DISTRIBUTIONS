Public Function K_STATS_Normal_InverseCumulativeFast( _
    ByVal Probability As Double) _
    As Double
'
'==============================================================================
' K_STATS_Normal_InverseCumulativeFast
'------------------------------------------------------------------------------
' PURPOSE
'   Returns the inverse standard normal cumulative distribution function using a
'   fast Double-to-Double contract.
'
' WHY THIS EXISTS
'   Monte Carlo engines transform large volumes of uniform random numbers into
'   standard-normal shocks. This routine avoids the overhead of a worksheet-
'   facing Variant/CVErr interface.
'
' INPUTS
'   Probability
'     Probability level.
'     Expected to be strictly between 0 and 1.
'
' RETURNS
'   Double
'     Standard-normal quantile.
'
' BEHAVIOR
'   - Clips Probability away from 0 and 1 as a defensive safeguard.
'   - Calls the private inverse-normal numerical kernel.
'   - Does not write to the Excel status bar.
'   - Does not return CVErr.
'
' ERROR POLICY
'   - Intended for validated numerical callers.
'   - Endpoint values are clipped rather than rejected.
'   - Public worksheet-facing validation remains the responsibility of
'     K_STATS_Normal_InverseCumulative or K_STATS_NormalStandard_InverseCumulative.
'
' DEPENDENCIES
'   - PROB_NormalInvCDF
'   - PROB_EPS
'
' CALLED FROM
'   - Monte Carlo engines
'   - VBA numerical routines
'
' UPDATED
'   2026-07-06
'==============================================================================
'
'------------------------------------------------------------------------------
' NORMALIZE PROBABILITY
'------------------------------------------------------------------------------
    'Clip probability away from singular endpoints
        If Probability <= 0# Then Probability = PROB_EPS
        If Probability >= 1# Then Probability = 1# - PROB_EPS
'------------------------------------------------------------------------------
' RETURN RESULT
'------------------------------------------------------------------------------
    'Return the inverse standard-normal quantile
        K_STATS_Normal_InverseCumulativeFast = PROB_NormalInvCDF(Probability)
End Function


Public Function K_STATS_Lognormal_Density( _
    ByVal X As Double, _
    ByVal MeanLog As Double, _
    ByVal StdDevLog As Double, _
    Optional ByRef Status As String = "") _
    As Variant
'
'==============================================================================
' K_STATS_Lognormal_Density
'------------------------------------------------------------------------------
' PURPOSE
'   Returns the lognormal probability density function at X.
'
' WHY THIS EXISTS
'   Lognormal distributions are used to model strictly positive variables such
'   as equity prices under geometric Brownian motion and other positive market
'   or economic quantities.
'
' INPUTS
'   X
'     Evaluation point.
'     Must be strictly positive.
'
'   MeanLog
'     Mean of Log(X).
'
'   StdDevLog
'     Standard deviation of Log(X).
'     Must be strictly positive.
'
'   Status
'     Optional ByRef diagnostic message.
'
' RETURNS
'   Variant
'     Success => Double density value.
'     Failure => CVErr(xlErrNum) or CVErr(xlErrValue).
'
' BEHAVIOR
'   - Validates X, MeanLog and StdDevLog.
'   - Computes Z = (Log(X) - MeanLog) / StdDevLog.
'   - Returns StandardNormalDensity(Z) / (X * StdDevLog).
'
' ERROR POLICY
'   - Invalid numeric domains return CVErr(xlErrNum).
'   - Unexpected runtime errors return CVErr(xlErrValue).
'   - Detailed diagnostic messages are written to Status and Application.StatusBar.
'
' DEPENDENCIES
'   - PROB_ValidateLognormalInputs
'   - PROB_NormalPDF
'   - PROB_SetStatus
'
' UPDATED
'   2026-07-06
'==============================================================================
'
'------------------------------------------------------------------------------
' DECLARE
'------------------------------------------------------------------------------
    Dim Z                   As Double          'Standardized log variate
    Dim FailMsg             As String          'Detailed failure message
'------------------------------------------------------------------------------
' INITIALIZE
'------------------------------------------------------------------------------
    'Route unexpected runtime errors to the error handler
        On Error GoTo Err_Handler
    'Clear diagnostic status
        PROB_SetStatus Status, vbNullString
    'Initialize the failure message buffer
        FailMsg = vbNullString
'------------------------------------------------------------------------------
' VALIDATE INPUTS
'------------------------------------------------------------------------------
    'Validate lognormal distribution inputs
        If Not PROB_ValidateLognormalInputs(X, MeanLog, StdDevLog, FailMsg) Then GoTo Fail_Num
'------------------------------------------------------------------------------
' COMPUTE DENSITY
'------------------------------------------------------------------------------
    'Compute standardized log variate
        Z = (Log(X) - MeanLog) / StdDevLog
    'Return lognormal density
        K_STATS_Lognormal_Density = PROB_NormalPDF(Z) / (X * StdDevLog)
'------------------------------------------------------------------------------
' RETURN SUCCESS
'------------------------------------------------------------------------------
    'Clear diagnostic status
        PROB_SetStatus Status, vbNullString
    'Exit before failure and error-handler blocks
        Exit Function
'------------------------------------------------------------------------------
' FAIL - NUMERIC
'------------------------------------------------------------------------------
Fail_Num:
    'Write diagnostics
        PROB_SetStatus Status, FailMsg
    'Return worksheet numeric error
        K_STATS_Lognormal_Density = CVErr(xlErrNum)
    'Exit before the error handler
        Exit Function
'------------------------------------------------------------------------------
' ERROR HANDLER
'------------------------------------------------------------------------------
Err_Handler:
    'Write unexpected runtime errors to diagnostics
        PROB_SetStatus Status, "Unexpected error in K_STATS_Lognormal_Density: " & Err.Description
    'Return worksheet value error
        K_STATS_Lognormal_Density = CVErr(xlErrValue)
End Function


Public Function K_STATS_Lognormal_Cumulative( _
    ByVal X As Double, _
    ByVal MeanLog As Double, _
    ByVal StdDevLog As Double, _
    Optional ByRef Status As String = "") _
    As Variant
'
'==============================================================================
' K_STATS_Lognormal_Cumulative
'------------------------------------------------------------------------------
' PURPOSE
'   Returns the lognormal cumulative distribution function at X.
'
' WHY THIS EXISTS
'   Lognormal cumulative probabilities are used for positive market variables,
'   GBM terminal-value examples and probability calculations for positive risk
'   factors.
'
' INPUTS
'   X
'     Evaluation point.
'     For X <= 0, the cumulative probability is 0.
'
'   MeanLog
'     Mean of Log(X).
'
'   StdDevLog
'     Standard deviation of Log(X).
'     Must be strictly positive.
'
' RETURNS
'   Variant
'     Success => Double cumulative probability.
'     Failure => CVErr(xlErrNum) or CVErr(xlErrValue).
'
' BEHAVIOR
'   - Validates MeanLog and StdDevLog.
'   - Returns 0 when X <= 0.
'   - Otherwise computes NormalCDF((Log(X) - MeanLog) / StdDevLog).
'
' ERROR POLICY
'   - Invalid parameters return CVErr(xlErrNum).
'   - Unexpected runtime errors return CVErr(xlErrValue).
'   - Detailed diagnostic messages are written to Status and Application.StatusBar.
'
' DEPENDENCIES
'   - PROB_NormalCDF
'   - PROB_SetStatus
'
' UPDATED
'   2026-07-06
'==============================================================================
'
'------------------------------------------------------------------------------
' DECLARE
'------------------------------------------------------------------------------
    Dim Z                   As Double          'Standardized log variate
    Dim FailMsg             As String          'Detailed failure message
'------------------------------------------------------------------------------
' INITIALIZE
'------------------------------------------------------------------------------
    'Route unexpected runtime errors to the error handler
        On Error GoTo Err_Handler
    'Clear diagnostic status
        PROB_SetStatus Status, vbNullString
    'Initialize the failure message buffer
        FailMsg = vbNullString
'------------------------------------------------------------------------------
' VALIDATE PARAMETERS
'------------------------------------------------------------------------------
    'Validate X is finite
        If Not PROB_IsFinite(X) Then
            FailMsg = "X must be a finite number"
            GoTo Fail_Num
        End If
    'Validate lognormal parameters
        If Not PROB_IsFinite(MeanLog) Then
            FailMsg = "MeanLog must be a finite number"
            GoTo Fail_Num
        End If

        If Not PROB_IsFinite(StdDevLog) Or StdDevLog <= 0# Then
            FailMsg = "StdDevLog must be a finite strictly positive number"
            GoTo Fail_Num
        End If
'------------------------------------------------------------------------------
' COMPUTE CUMULATIVE PROBABILITY
'------------------------------------------------------------------------------
    'Return zero for non-positive evaluation points
        If X <= 0# Then
            K_STATS_Lognormal_Cumulative = 0#
            PROB_SetStatus Status, vbNullString
            Exit Function
        End If
    'Compute standardized log variate
        Z = (Log(X) - MeanLog) / StdDevLog
    'Return lognormal cumulative probability
        K_STATS_Lognormal_Cumulative = PROB_NormalCDF(Z)
'------------------------------------------------------------------------------
' RETURN SUCCESS
'------------------------------------------------------------------------------
    'Clear diagnostic status
        PROB_SetStatus Status, vbNullString
    'Exit before failure and error-handler blocks
        Exit Function
'------------------------------------------------------------------------------
' FAIL - NUMERIC
'------------------------------------------------------------------------------
Fail_Num:
    'Write diagnostics
        PROB_SetStatus Status, FailMsg
    'Return worksheet numeric error
        K_STATS_Lognormal_Cumulative = CVErr(xlErrNum)
    'Exit before the error handler
        Exit Function
'------------------------------------------------------------------------------
' ERROR HANDLER
'------------------------------------------------------------------------------
Err_Handler:
    'Write unexpected runtime errors to diagnostics
        PROB_SetStatus Status, "Unexpected error in K_STATS_Lognormal_Cumulative: " & Err.Description
    'Return worksheet value error
        K_STATS_Lognormal_Cumulative = CVErr(xlErrValue)
End Function


Public Function K_STATS_Lognormal_InverseCumulative( _
    ByVal Probability As Double, _
    ByVal MeanLog As Double, _
    ByVal StdDevLog As Double, _
    Optional ByRef Status As String = "") _
    As Variant
'
'==============================================================================
' K_STATS_Lognormal_InverseCumulative
'------------------------------------------------------------------------------
' PURPOSE
'   Returns the inverse lognormal cumulative distribution function.
'
' WHY THIS EXISTS
'   The inverse lognormal distribution maps probabilities into positive quantiles
'   for variables whose logarithm is normally distributed.
'
' INPUTS
'   Probability
'     Probability level.
'     Must be strictly between 0 and 1.
'
'   MeanLog
'     Mean of Log(X).
'
'   StdDevLog
'     Standard deviation of Log(X).
'     Must be strictly positive.
'
' RETURNS
'   Variant
'     Success => Double positive lognormal quantile.
'     Failure => CVErr(xlErrNum) or CVErr(xlErrValue).
'
' BEHAVIOR
'   - Validates probability and lognormal parameters.
'   - Computes Z = StandardNormalInverseCDF(Probability).
'   - Returns Exp(MeanLog + StdDevLog * Z).
'
' ERROR POLICY
'   - Invalid numeric domains return CVErr(xlErrNum).
'   - Unexpected runtime errors return CVErr(xlErrValue).
'   - Detailed diagnostic messages are written to Status and Application.StatusBar.
'
' DEPENDENCIES
'   - PROB_NormalInvCDF
'   - PROB_SafeExp
'   - PROB_SetStatus
'
' UPDATED
'   2026-07-06
'==============================================================================
'
'------------------------------------------------------------------------------
' DECLARE
'------------------------------------------------------------------------------
    Dim Z                   As Double          'Standard normal quantile
    Dim LogQuantile         As Double          'Lognormal log-quantile
    Dim FailMsg             As String          'Detailed failure message
'------------------------------------------------------------------------------
' INITIALIZE
'------------------------------------------------------------------------------
    'Route unexpected runtime errors to the error handler
        On Error GoTo Err_Handler
    'Clear diagnostic status
        PROB_SetStatus Status, vbNullString
    'Initialize the failure message buffer
        FailMsg = vbNullString
'------------------------------------------------------------------------------
' VALIDATE INPUTS
'------------------------------------------------------------------------------
    'Validate probability domain
        If Not PROB_IsValidProbabilityOpen(Probability) Then
            FailMsg = "Probability must be strictly between 0 and 1"
            GoTo Fail_Num
        End If
    'Validate log-space parameters
        If Not PROB_IsFinite(MeanLog) Then
            FailMsg = "MeanLog must be a finite number"
            GoTo Fail_Num
        End If

        If Not PROB_IsFinite(StdDevLog) Or StdDevLog <= 0# Then
            FailMsg = "StdDevLog must be a finite strictly positive number"
            GoTo Fail_Num
        End If
'------------------------------------------------------------------------------
' COMPUTE QUANTILE
'------------------------------------------------------------------------------
    'Compute standard normal quantile
        Z = PROB_NormalInvCDF(Probability)
    'Compute log-quantile
        LogQuantile = MeanLog + StdDevLog * Z
    'Return lognormal quantile with safe exponential guard
        K_STATS_Lognormal_InverseCumulative = PROB_SafeExp(LogQuantile)
'------------------------------------------------------------------------------
' RETURN SUCCESS
'------------------------------------------------------------------------------
    'Clear diagnostic status
        PROB_SetStatus Status, vbNullString
    'Exit before failure and error-handler blocks
        Exit Function
'------------------------------------------------------------------------------
' FAIL - NUMERIC
'------------------------------------------------------------------------------
Fail_Num:
    'Write diagnostics
        PROB_SetStatus Status, FailMsg
    'Return worksheet numeric error
        K_STATS_Lognormal_InverseCumulative = CVErr(xlErrNum)
    'Exit before the error handler
        Exit Function
'------------------------------------------------------------------------------
' ERROR HANDLER
'------------------------------------------------------------------------------
Err_Handler:
    'Write unexpected runtime errors to diagnostics
        PROB_SetStatus Status, "Unexpected error in K_STATS_Lognormal_InverseCumulative: " & Err.Description
    'Return worksheet value error
        K_STATS_Lognormal_InverseCumulative = CVErr(xlErrValue)
End Function


Public Function K_STATS_Lognormal_Mean( _
    ByVal MeanLog As Double, _
    ByVal StdDevLog As Double, _
    Optional ByRef Status As String = "") _
    As Variant
'
'==============================================================================
' K_STATS_Lognormal_Mean
'------------------------------------------------------------------------------
' PURPOSE
'   Returns the arithmetic mean of a lognormal distribution.
'
' INPUTS
'   MeanLog
'     Mean of Log(X).
'
'   StdDevLog
'     Standard deviation of Log(X).
'
' RETURNS
'   Variant
'     Success => Exp(MeanLog + 0.5 * StdDevLog^2).
'     Failure => CVErr(xlErrNum) or CVErr(xlErrValue).
'
' UPDATED
'   2026-07-06
