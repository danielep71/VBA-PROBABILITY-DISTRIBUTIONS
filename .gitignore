#==============================================================================
# VBA-Probability-Distributions .gitignore
#------------------------------------------------------------------------------
# PURPOSE
#   Ignore local, temporary and generated files while keeping exported VBA source
#   modules and intentional demo workbooks trackable.
#==============================================================================

#------------------------------------------------------------------------------
# OFFICE TEMPORARY / LOCK FILES
#------------------------------------------------------------------------------
~$*
~$*.xls*
~$*.doc*
~$*.ppt*
*.tmp
*.temp
*.bak
*.backup
*.xlk

#------------------------------------------------------------------------------
# OPERATING SYSTEM METADATA
#------------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
desktop.ini

#------------------------------------------------------------------------------
# EDITOR / IDE LOCAL SETTINGS
#------------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

#------------------------------------------------------------------------------
# LOGS
#------------------------------------------------------------------------------
*.log

#------------------------------------------------------------------------------
# GENERATED OUTPUTS
#------------------------------------------------------------------------------
output/
outputs/
dist/
build/
temp/
tmp/

#------------------------------------------------------------------------------
# TEST ARTIFACTS
#------------------------------------------------------------------------------
test-output/
test-results/
coverage/

#------------------------------------------------------------------------------
# KEEP THESE FILE TYPES TRACKABLE
#------------------------------------------------------------------------------
# Exported VBA source:
#   *.bas
#   *.cls
#   *.frm
#   *.frx
#
# Intentional Excel demo files:
#   *.xlsm
#   *.xlam
#
# Documentation:
#   *.md
#   *.txt
